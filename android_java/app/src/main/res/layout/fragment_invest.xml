<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jio_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Investment Hub"
            android:textColor="@color/jio_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grow your wealth with expert-picked schemes"
            android:textColor="@color/jio_text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Mutual Funds Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivMF"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:background="#E1F5FE"
                        android:padding="12dp"
                        android:backgroundTint="#E1F5FE"
                        app:tint="#039BE5" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivMF"
                        android:layout_marginStart="16dp"
                        android:text="Mutual Funds"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/jio_text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivMF"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="24dp"
                        android:text="SIP starts at ₹500"
                        android:textSize="12sp"
                        android:textColor="#039BE5" />
                </RelativeLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Invest in top-performing Equity, Debt, or Hybrid funds. Direct plans with zero commission."
                    android:textColor="@color/jio_text_secondary"
                    android:textSize="13sp" />
                <Button
                    android:id="@+id/btnInvestMF"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Explore Funds"
                    android:textAllCaps="false"
                    android:backgroundTint="#039BE5"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fixed Deposits Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivFD"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@android:drawable/ic_menu_save"
                        android:background="#E8F5E9"
                        android:padding="12dp"
                        android:backgroundTint="#E8F5E9"
                        app:tint="#43A047" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivFD"
                        android:layout_marginStart="16dp"
                        android:text="Fixed Deposits"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/jio_text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivFD"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="24dp"
                        android:text="Up to 8.5% p.a."
                        android:textSize="12sp"
                        android:textColor="#43A047" />
                </RelativeLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Secure your future with guaranteed returns. Compare rates across top banks."
                    android:textColor="@color/jio_text_secondary"
                    android:textSize="13sp" />
                <Button
                    android:id="@+id/btnInvestFD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Check Rates"
                    android:textAllCaps="false"
                    android:backgroundTint="#43A047"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- India Post Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivPost"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:background="#FFF3E0"
                        android:padding="12dp"
                        android:backgroundTint="#FFF3E0"
                        app:tint="#F4511E" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivPost"
                        android:layout_marginStart="16dp"
                        android:text="India Post Schemes"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/jio_text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/ivPost"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="24dp"
                        android:text="PPF, SSY &amp; NSC"
                        android:textSize="12sp"
                        android:textColor="#F4511E" />
                </RelativeLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Government-backed savings for long-term goals. High safety and tax benefits."
                    android:textColor="@color/jio_text_secondary"
                    android:textSize="13sp" />
                <Button
                    android:id="@+id/btnInvestPost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="View Schemes"
                    android:textAllCaps="false"
                    android:backgroundTint="#F4511E"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View 
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
