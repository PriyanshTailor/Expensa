<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jio_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/jio_background"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header: Greeting and Profile -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textColor="@color/jio_text_secondary"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Priyansh Tailor"
                        android:textColor="@color/jio_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/circle_bg"
                    android:backgroundTint="@color/white"
                    android:padding="10dp"
                    app:tint="@color/jio_primary" />
            </RelativeLayout>

            <!-- Hero Card: Total Wealth -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@color/white">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Wealth"
                        android:textSize="14sp"
                        android:textColor="@color/jio_text_secondary" />
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/tvTotalWealth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹1,70,411.73"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/jio_text_primary" />
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_popup_sync"
                            android:layout_toEndOf="@id/tvTotalWealth"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            app:tint="@color/jio_primary" />
                    </RelativeLayout>
                    
                    <View 
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/jio_divider"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp" />
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Savings account"
                                android:textSize="12sp"
                                android:textColor="@color/jio_text_secondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹42,530"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/jio_text_primary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mutual Funds"
                                android:textSize="12sp"
                                android:textColor="@color/jio_text_secondary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹1,27,881"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/jio_text_primary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Quick Tools Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:rowCount="2"
                android:layout_marginBottom="24dp">
                
                <!-- Tool 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:padding="12dp"
                        android:background="@drawable/circle_bg"
                        android:backgroundTint="#FFF3E0"
                        app:tint="@color/jio_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan any QR"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/jio_text_primary" />
                </LinearLayout>

                <!-- Tool 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_send"
                        android:padding="12dp"
                        android:background="@drawable/circle_bg"
                        android:backgroundTint="#FFF3E0"
                        app:tint="@color/jio_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pay via UPI"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/jio_text_primary" />
                </LinearLayout>

                <!-- Tool 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:padding="12dp"
                        android:background="@drawable/circle_bg"
                        android:backgroundTint="#FFF3E0"
                        app:tint="@color/jio_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check balance"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/jio_text_primary" />
                </LinearLayout>

                <!-- Tool 4 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:padding="12dp"
                        android:background="@drawable/circle_bg"
                        android:backgroundTint="#FFF3E0"
                        app:tint="@color/jio_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPI history"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/jio_text_primary" />
                </LinearLayout>
            </GridLayout>

            <!-- Cashflow Analysis -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cashflow analysis"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/jio_text_primary"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get insights into monthly income &amp; expenses from linked bank accounts"
                        android:textColor="@color/jio_text_secondary"
                        android:textSize="12sp" />
                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Details"
                        android:layout_marginTop="12dp"
                        android:textAllCaps="false"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/jio_primary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent Transactions from SMS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent SMS Transactions"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/jio_text_primary"
                android:layout_marginBottom="12dp" />

            <!-- Placeholder for dynamic transaction items -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <View 
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
